---
interface StatItem {
    value?: string | null;
    label?: string | null;
}

interface Props {
    items?: StatItem[] | null;
}

const { items } = Astro.props;
const stats = items ?? [];
---

{
    stats.length > 0 && (
        <section class="bg-gray-900 text-white">
            <div class="max-w-6xl mx-auto px-4 py-16">
                <dl
                    class={`grid gap-8 ${stats.length <= 3 ? `grid-cols-${stats.length}` : 'grid-cols-2 md:grid-cols-4'}`}
                >
                    {stats.map((stat) => (
                        <div class="text-center">
                            {stat.value && (
                                <dt class="text-3xl md:text-4xl font-bold mb-1">
                                    {stat.value}
                                </dt>
                            )}
                            {stat.label && (
                                <dd class="text-sm text-gray-400 uppercase tracking-wide">
                                    {stat.label}
                                </dd>
                            )}
                        </div>
                    ))}
                </dl>
            </div>
        </section>
    )
}
