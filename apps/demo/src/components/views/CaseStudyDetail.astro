---
import Site from '../../layouts/Site.astro';
import Blocks from '../blocks/Blocks.astro';
import { t, localizedPath } from '../../lib/site.ts';
import type { Locale } from '../../lib/site.ts';
import type { Entry } from 'astromech';

interface Props {
    locale: Locale;
    slug: string;
    cs: Entry;
}

const { locale, slug, cs } = Astro.props;

const customer = cs.fields?.customer as string | null | undefined;
const industry = cs.fields?.industry as string | null | undefined;
const summary = cs.fields?.summary as string | null | undefined;
const blocks = cs.fields?.content as unknown[] | null | undefined;
const metrics = cs.fields?.metrics as
    | { value?: string; label?: string }[]
    | null
    | undefined;
const quote = cs.fields?.quote as
    | { text?: string; author?: string; role?: string }
    | null
    | undefined;
const logo = cs.fields?.logo as { url?: string } | null | undefined;
const relatedPosts = cs.fields?.related_posts as Entry[] | null | undefined;
---

<Site
    locale={locale}
    seoType="caseStudy"
    seoSlug={slug}
    seoTitle={cs.title}
    seoDescription={summary ?? undefined}
>
    <div class="max-w-6xl mx-auto px-4 py-8">
        <a
            href={localizedPath('/customers', locale)}
            class="text-sm text-gray-400 hover:text-gray-700 transition-colors"
        >
            {t('backToCustomers', locale)}
        </a>
    </div>

    <!-- Hero section -->
    <header class="max-w-6xl mx-auto px-4 pb-12">
        <div class="flex items-start gap-6 flex-wrap">
            {
                logo?.url && (
                    <img src={logo.url} alt={cs.title} class="h-12 w-auto grayscale" />
                )
            }
            <div>
                {
                    industry && (
                        <p class="text-xs text-gray-400 uppercase tracking-wider mb-2 capitalize">
                            {t('industry', locale)}: {industry}
                        </p>
                    )
                }
                <h1 class="text-3xl md:text-4xl font-bold text-gray-900">{cs.title}</h1>
                {
                    customer && customer !== cs.title && (
                        <p class="text-gray-500 mt-1">{customer}</p>
                    )
                }
            </div>
        </div>

        {
            summary && (
                <p class="mt-6 text-lg text-gray-600 leading-relaxed max-w-2xl">
                    {summary}
                </p>
            )
        }
    </header>

    <!-- Metrics -->
    {
        metrics && metrics.length > 0 && (
            <section class="bg-gray-900 text-white">
                <div class="max-w-6xl mx-auto px-4 py-12">
                    <h2 class="text-sm font-medium uppercase tracking-wider text-gray-400 mb-8">
                        {t('metrics', locale)}
                    </h2>
                    <dl class="grid grid-cols-2 md:grid-cols-4 gap-8">
                        {metrics.map((m) => (
                            <div>
                                {m.value && <dt class="text-3xl font-bold">{m.value}</dt>}
                                {m.label && (
                                    <dd class="text-sm text-gray-400 mt-1">{m.label}</dd>
                                )}
                            </div>
                        ))}
                    </dl>
                </div>
            </section>
        )
    }

    <!-- Content blocks -->
    {
        blocks && blocks.length > 0 && (
            <Blocks blocks={blocks as { type: string; [key: string]: unknown }[]} />
        )
    }

    <!-- Quote -->
    {
        quote?.text && (
            <section class="max-w-3xl mx-auto px-4 py-12">
                <blockquote class="border-l-4 border-gray-300 pl-6">
                    <p class="text-xl italic text-gray-700 leading-relaxed">
                        &ldquo;{quote.text}&rdquo;
                    </p>
                    {(quote.author || quote.role) && (
                        <footer class="mt-4">
                            {quote.author && (
                                <p class="font-semibold text-gray-900 text-sm">
                                    {quote.author}
                                </p>
                            )}
                            {quote.role && (
                                <p class="text-xs text-gray-400">{quote.role}</p>
                            )}
                        </footer>
                    )}
                </blockquote>
            </section>
        )
    }

    <!-- Related posts -->
    {
        relatedPosts && relatedPosts.length > 0 && (
            <section class="max-w-6xl mx-auto px-4 py-12 border-t border-gray-200">
                <h2 class="text-lg font-semibold text-gray-900 mb-6">
                    {t('relatedPosts', locale)}
                </h2>
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {relatedPosts.map((post) => (
                        <li>
                            <a
                                href={localizedPath(`/blog/${post.slug}`, locale)}
                                class="block border border-gray-200 rounded-lg p-4 hover:border-gray-300 transition-colors"
                            >
                                <p class="font-medium text-gray-900">{post.title}</p>
                            </a>
                        </li>
                    ))}
                </ul>
            </section>
        )
    }
</Site>
