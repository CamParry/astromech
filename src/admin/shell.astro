---
/**
 * Astromech Admin Shell
 *
 * A bare-bones SSR page that serves as the SPA mount point.
 * All admin UI routing is handled client-side by TanStack Router.
 *
 * Registered at `${adminRoute}/[...path]` by Astromech's route registration.
 */
import AdminApp from './main.tsx';
export const prerender = false;

// `data-theme` is the single source of truth for colour. For returning users we
// stamp it from the `am-theme` cookie so the correct theme paints with zero
// flash. First-time visitors have no cookie — the inline script below resolves
// their system preference before paint.
const cookieTheme = Astro.cookies.get('am-theme')?.value;
const initialTheme = cookieTheme === 'light' || cookieTheme === 'dark' ? cookieTheme : undefined;
---

<!DOCTYPE html>
<html lang="en" data-theme={initialTheme}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content="noindex, nofollow" />
        <title>Astromech CMS</title>
        {/* First-time visitors have no cookie, so the server left data-theme
            unset — resolve it from the system preference before paint. No-ops
            when the server already stamped a cookie-driven theme. */}
        <script is:inline>
            if (!document.documentElement.hasAttribute('data-theme')) {
                document.documentElement.dataset.theme = window.matchMedia(
                    '(prefers-color-scheme: dark)'
                ).matches
                    ? 'dark'
                    : 'light';
            }
        </script>
    </head>
    <body>
        <AdminApp client:only="react" />
    </body>
</html>
