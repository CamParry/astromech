{
    "name": "astromech-monorepo",
    "private": true,
    "type": "module",
    "author": "Cam",
    "license": "MIT",
    "workspaces": [
        "packages/astromech",
        "packages/plugins/*",
        "apps/*"
    ],
    "scripts": {
        "dev": "npm run dev -w astromech",
        "build": "npm run build -w astromech && npm run build -w @astromech/menus -w @astromech/redirects -w @astromech/seo -w @astromech/backups",
        "typecheck": "npm run typecheck -w astromech",
        "lint": "npm run lint -w astromech",
        "lint:deps": "npm run lint:deps -w astromech",
        "format": "npm run format -w astromech",
        "format:check": "npm run format:check -w astromech",
        "lint:css": "npm run lint:css -w astromech",
        "test": "npm run test -w astromech",
        "test:run": "npm run test:run -w astromech",
        "db:generate": "npm run db:generate -w astromech-demo",
        "db:init": "npm run db:init -w astromech-demo",
        "db:push": "npm run db:push -w astromech",
        "db:seed": "npm run db:seed -w astromech",
        "db:seed:demo": "tsx apps/demo/seed.ts",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "npm run build && changeset publish",
        "prepare": "husky"
    },
    "devDependencies": {
        "@changesets/changelog-github": "^0.5.2",
        "@changesets/cli": "^2.30.0",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "3.8.1",
        "prettier-plugin-astro": "0.14.1",
        "stylelint": "^17.6.0",
        "stylelint-config-recess-order": "^7.7.0",
        "stylelint-order": "^8.1.1",
        "typescript-eslint": "^8.57.1"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.css": [
            "stylelint --fix",
            "prettier --write"
        ],
        "*.{json,md,astro}": [
            "prettier --write"
        ]
    }
}
