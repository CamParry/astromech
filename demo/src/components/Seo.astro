---
/**
 * SEO head tags. Resolves via Astromech.plugins.seo.meta when type+slug are
 * given; falls back to props.
 */
import Astromech from 'astromech/local';
import type { Locale } from '../lib/site.ts';
import { localizedPath } from '../lib/site.ts';

interface Props {
    /** Entry type — used for seo.meta lookup. */
    type?: string;
    /** Entry slug — used for seo.meta lookup. */
    slug?: string | null;
    /** Fallback title when seo.meta returns nothing. */
    title?: string;
    /** Fallback description. */
    description?: string | null;
    /** Canonical URL (full). */
    canonical?: string;
    /** OG image URL. */
    ogImage?: string | null;
    /** Active locale. */
    locale?: Locale;
    /**
     * Locale map from the entry (`entry.locales`): { locale: entryId }.
     * Used to emit hreflang links. The id values are not slugs — caller must
     * pass in pre-resolved `hreflangUrls` if they want full hreflang support.
     */
    hreflangUrls?: Record<string, string>;
    /** Site origin e.g. https://astromech.dev */
    siteUrl?: string;
}

const {
    type,
    slug,
    title: propTitle,
    description: propDescription,
    canonical,
    ogImage: propOgImage,
    hreflangUrls,
    siteUrl = '',
} = Astro.props;

let resolvedTitle = propTitle ?? 'Astromech';
let resolvedDescription = propDescription ?? null;
let resolvedOgImage = propOgImage ?? null;

if (type && slug) {
    try {
        const meta = await Astromech.plugins.seo.meta({ type, slug });
        if (meta) {
            resolvedTitle = meta.title ?? resolvedTitle;
            resolvedDescription = meta.description ?? resolvedDescription;
            resolvedOgImage = meta.ogImage ?? resolvedOgImage;
        }
    } catch {
        // seo plugin not available or entry not found — use fallbacks
    }
}

const canonicalUrl = canonical ?? (siteUrl ? `${siteUrl}${Astro.url.pathname}` : null);
---

<title>{resolvedTitle}</title>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
{resolvedDescription && <meta name="description" content={resolvedDescription} />}
{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

<!-- Open Graph -->
<meta property="og:title" content={resolvedTitle} />
{resolvedDescription && <meta property="og:description" content={resolvedDescription} />}
{resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}

<!-- hreflang alternates -->
{hreflangUrls && Object.entries(hreflangUrls).map(([lang, href]) => (
    <link rel="alternate" hreflang={lang} href={href} />
))}
