---
import Site from '../../layouts/Site.astro';
import { t, localizedPath } from '../../lib/site.ts';
import type { Locale } from '../../lib/site.ts';
import type { Entry } from 'astromech';

interface Props {
    locale: Locale;
    category: Entry;
    posts: Entry[];
}

const { locale, category, posts } = Astro.props;
---

<Site locale={locale} seoTitle={`${t('category', locale)}: ${category.title}`}>
    <div class="max-w-6xl mx-auto px-4 py-16">
        <a href={localizedPath('/blog', locale)} class="text-sm text-gray-400 hover:text-gray-700 transition-colors mb-8 inline-block">
            {t('backToBlog', locale)}
        </a>

        <h1 class="text-3xl font-bold text-gray-900 mb-2">{category.title}</h1>
        {category.fields?.description && (
            <p class="text-gray-500 mb-10">{category.fields.description as string}</p>
        )}

        {posts.length === 0
            ? <p class="text-gray-400">{t('noPostsFound', locale)}</p>
            : (
                <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
                    {posts.map((post) => {
                        const excerpt = post.fields?.excerpt as string | null | undefined;
                        return (
                            <li class="border border-gray-200 rounded-lg p-5 hover:border-gray-300 transition-colors">
                                <h2 class="font-semibold text-gray-900 mb-2">
                                    <a href={localizedPath(`/blog/${post.slug}`, locale)} class="hover:underline">
                                        {post.title}
                                    </a>
                                </h2>
                                {excerpt && <p class="text-sm text-gray-500 line-clamp-2">{excerpt}</p>}
                                <a
                                    href={localizedPath(`/blog/${post.slug}`, locale)}
                                    class="inline-block mt-3 text-sm font-medium text-gray-900 hover:underline"
                                >
                                    {t('readMore', locale)} →
                                </a>
                            </li>
                        );
                    })}
                </ul>
            )
        }
    </div>
</Site>
