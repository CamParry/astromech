---
import Site from '../../layouts/Site.astro';
import { getCaseStudies } from '../../lib/data.ts';
import { t, localizedPath } from '../../lib/site.ts';
import type { Locale } from '../../lib/site.ts';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
const caseStudies = await getCaseStudies(locale);
---

<Site locale={locale} seoTitle={t('customers', locale)}>
    <div class="max-w-6xl mx-auto px-4 py-16">
        <h1 class="text-3xl font-bold text-gray-900 mb-10">{t('customers', locale)}</h1>
        {caseStudies.length === 0
            ? <p class="text-gray-400">No case studies found.</p>
            : (
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {caseStudies.map((cs) => {
                        const logo = cs.fields?.logo as { url?: string } | null | undefined;
                        const summary = cs.fields?.summary as string | null | undefined;
                        const industry = cs.fields?.industry as string | null | undefined;
                        return (
                            <li class="border border-gray-200 rounded-lg p-6 hover:border-gray-300 transition-colors">
                                {logo?.url && (
                                    <img src={logo.url} alt={cs.title} class="h-8 w-auto mb-4 grayscale" />
                                )}
                                <h2 class="font-semibold text-gray-900 mb-1">
                                    <a href={localizedPath(`/customers/${cs.slug}`, locale)} class="hover:underline">
                                        {cs.title}
                                    </a>
                                </h2>
                                {industry && (
                                    <p class="text-xs text-gray-400 uppercase tracking-wide mb-3 capitalize">{industry}</p>
                                )}
                                {summary && (
                                    <p class="text-sm text-gray-500 line-clamp-3">{summary}</p>
                                )}
                                <a
                                    href={localizedPath(`/customers/${cs.slug}`, locale)}
                                    class="inline-block mt-4 text-sm font-medium text-gray-900 hover:underline"
                                >
                                    {t('readMore', locale)} →
                                </a>
                            </li>
                        );
                    })}
                </ul>
            )
        }
    </div>
</Site>
