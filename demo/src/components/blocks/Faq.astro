---
interface FaqItem {
    question?: string | null;
    answer?: string | null;
}

interface Props {
    heading?: string | null;
    items?: FaqItem[] | null;
}

const { heading, items } = Astro.props;
const faqItems = items ?? [];
---

<section class="max-w-3xl mx-auto px-4 py-16">
    {heading && (
        <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 text-gray-900">
            {heading}
        </h2>
    )}
    {faqItems.length > 0 && (
        <dl class="divide-y divide-gray-200">
            {faqItems.map((item) => (
                <div class="py-6">
                    {item.question && (
                        <dt class="font-semibold text-gray-900 mb-2">{item.question}</dt>
                    )}
                    {item.answer && (
                        <dd class="text-gray-500 leading-relaxed">{item.answer}</dd>
                    )}
                </div>
            ))}
        </dl>
    )}
</section>
