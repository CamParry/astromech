---
interface LogoItem {
    url?: string;
    alt?: string;
    filename?: string;
}

interface Props {
    heading?: string | null;
    logos?: LogoItem[] | LogoItem | null;
}

const { heading, logos } = Astro.props;
// logos may be a single object or an array
const logoList: LogoItem[] = logos
    ? Array.isArray(logos)
        ? logos
        : [logos]
    : [];
---

<section class="border-y border-gray-100">
    <div class="max-w-6xl mx-auto px-4 py-12">
        {heading && (
            <p class="text-center text-sm font-medium text-gray-400 uppercase tracking-wider mb-8">
                {heading}
            </p>
        )}
        {logoList.length > 0 && (
            <div class="flex flex-wrap items-center justify-center gap-8">
                {logoList.map((logo) => (
                    logo.url && (
                        <img
                            src={logo.url}
                            alt={logo.alt ?? logo.filename ?? ''}
                            class="h-8 w-auto grayscale opacity-60 hover:opacity-100 transition-opacity"
                        />
                    )
                ))}
            </div>
        )}
    </div>
</section>
