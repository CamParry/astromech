---
interface Props {
    image?: { url?: string; alt?: string } | null;
    caption?: string | null;
}

const { image, caption } = Astro.props;
---

{image?.url && (
    <figure class="max-w-4xl mx-auto px-4 py-8">
        <img
            src={image.url}
            alt={caption ?? image.alt ?? ''}
            class="w-full rounded-lg object-cover"
        />
        {caption && (
            <figcaption class="mt-3 text-center text-sm text-gray-400">
                {caption}
            </figcaption>
        )}
    </figure>
)}
