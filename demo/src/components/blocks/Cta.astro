---
interface Props {
    heading?: string | null;
    text?: string | null;
    button?: { label?: string; href?: string; url?: string } | null;
}

const { heading, text, button } = Astro.props;
const btnHref = button?.href ?? button?.url ?? null;
const btnLabel = button?.label ?? null;
---

<section class="bg-gray-900 text-white">
    <div class="max-w-3xl mx-auto px-4 py-16 text-center">
        {heading && (
            <h2 class="text-2xl md:text-3xl font-bold mb-4">{heading}</h2>
        )}
        {text && (
            <p class="text-gray-300 mb-8 leading-relaxed">{text}</p>
        )}
        {btnHref && btnLabel && (
            <a
                href={btnHref}
                class="inline-block bg-white text-gray-900 font-semibold px-6 py-3 rounded hover:bg-gray-100 transition-colors"
            >
                {btnLabel}
            </a>
        )}
    </div>
</section>
