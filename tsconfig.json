{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "stripInternal": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "types": ["node"],
        "paths": {
            "@/*": ["./src/*"],
            "@tests/*": ["./tests/_support/*"],
            "astromech": ["./src/index.ts"],
            "astromech/fields": ["./src/exports/fields.ts"],
            "astromech/columns": ["./src/exports/columns.ts"],
            "astromech/plugin-kit": ["./src/exports/plugin-kit.ts"],
            "@astromech/menus": ["./packages/menus/src/index.ts"],
            "@astromech/redirects": ["./packages/redirects/src/index.ts"],
            "@astromech/redirects/schema": [
                "./packages/redirects/src/schema/redirects.ts"
            ]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "demo"]
}
